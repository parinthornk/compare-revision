<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage name="AM-Set-GCP-Logging-Settings" continueOnError="true">
  <!-- use this in Logs Explorer to find the log entries -->
  <AssignVariable>
    <Name>gcplogging.logid</Name>
    <Value>API-Tracking</Value>
  </AssignVariable>
  <!-- the following comes from the (shredded) Service Account JSON key file -->
  <AssignVariable>
    <Name>gcplogging.projectid</Name>
    <Ref>private.project_id</Ref>
  </AssignVariable>
  <IgnoreUnresolvedVariables>false</IgnoreUnresolvedVariables>
</AssignMessage>
