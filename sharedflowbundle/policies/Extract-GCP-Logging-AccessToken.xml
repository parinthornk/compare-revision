<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ExtractVariables name="Extract-GCP-Logging-AccessToken" continueOnError="true">
  <Source>tokenResponse</Source>
  <VariablePrefix>gcplogging</VariablePrefix>
  <JSONPayload>
    <Variable name="newtoken">
      <JSONPath>$.access_token</JSONPath>
    </Variable>
    <Variable name="expires_in">
      <JSONPath>$.expires_in</JSONPath>
    </Variable>
  </JSONPayload>
</ExtractVariables>
