<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage name="AM-Set-GCP-Logging-Token" continueOnError="true">
  <AssignVariable>
    <Name>gcplogging.token</Name>
    <Ref>gcplogging.newtoken</Ref>
  </AssignVariable>
  <AssignVariable>
    <Name>gcplogging.logid</Name>
    <Ref>gcplogging.newtoken</Ref>
  </AssignVariable>
  <IgnoreUnresolvedVariables>false</IgnoreUnresolvedVariables>
</AssignMessage>
