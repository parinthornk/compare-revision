<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<PopulateCache name="Cache-Put-GCP-Logging-Token" continueOnError="true">
  <Scope>Application</Scope>
  <Source>gcplogging.newtoken</Source>
  <CacheKey>
    <!-- <Prefix>gcplogging.token</Prefix> -->
    <KeyFragment>gcplogging.token</KeyFragment>
  </CacheKey>
  <ExpirySettings>
    <TimeoutInSeconds>3600</TimeoutInSeconds>
  </ExpirySettings>
</PopulateCache>
